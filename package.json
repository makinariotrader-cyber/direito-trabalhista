{
  "name": "direito-trabalhista",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "node generate-sitemap.mjs",
    "preview": "vite preview",
    "agente": "node agente-redator.mjs",
    "build-blog": "node agente-redator.mjs && npm run build",
    "publish-blog": "node agente-redator.mjs && npm run build && git add -A && git commit -m 'feat: novo post do blog' && git push",
    "juridico": "node agente-juridico.mjs",
    "juridico-tst": "node agente-juridico.mjs tst",
    "juridico-stf": "node agente-juridico.mjs stf",
    "juridico-planalto": "node agente-juridico.mjs planalto",
    "juridico-relatorio": "node agente-juridico.mjs relatorio",
    "juridico-dry-run": "node agente-juridico.mjs --dry-run",
    "juridico-publish": "node agente-juridico.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
